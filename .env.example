DATABASE_URL=postgresql://user:password@localhost:5432/beijerink
JWT_SECRET=change-me-to-a-random-64-char-hex-string
ADMIN_PASSWORD=change-me

# Cloudflare R2 (for image uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=beijer-ink-images
R2_PUBLIC_URL=

# Daily SFTP backups
BACKUP_ENABLED=false
BACKUP_CRON=0 2 * * *
BACKUP_TIMEZONE=Europe/London
BACKUP_SFTP_HOST=
BACKUP_SFTP_PORT=22
BACKUP_SFTP_USERNAME=
BACKUP_SFTP_PASSWORD=
BACKUP_SFTP_REMOTE_DIR=/beijer-ink-backups

PORT=3000
NODE_ENV=development
